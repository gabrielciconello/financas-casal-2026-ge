{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist-api",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/api/**/*", "src/services/**/*", "src/middleware/**/*",
              "src/utils/**/*", "src/validators/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.tsx"]
}