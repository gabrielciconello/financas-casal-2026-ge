{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/api/**/*",
    "src/services/**/*",
    "src/middleware/**/*",
    "src/utils/**/*",
    "src/validators/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.tsx",
    "src/services/supabase.browser.ts",
    "src/hooks/**/*",
    "src/pages/**/*",
    "src/components/**/*"
  ]
}