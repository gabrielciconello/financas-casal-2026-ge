{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/pages/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/styles/**/*",
    "src/services/supabase.browser.ts",
    "src/types/**/*",
    "src/utils/index.ts",
    "src/App.tsx",
    "src/index.tsx",
    "src/vite-env.d.ts"
  ]
}